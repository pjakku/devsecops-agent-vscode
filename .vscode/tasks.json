{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "compile"
      ],
      "windows": {
        "command": "npm.cmd"
      },
      "group": "build",
      "problemMatcher": "$tsc",
      "label": "npm: compile"
    },
    {
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "watch"
      ],
      "windows": {
        "command": "npm.cmd"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "label": "npm: watch"
    }
  ]
}
