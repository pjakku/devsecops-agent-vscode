{
  "name": "devsecops-agent-vscode",
  "displayName": "DevSecOps Agent",
  "description": "VS Code extension MVP for running DevSecOps Agent workspace scans.",
  "version": "0.4.0",
  "publisher": "hhs-technology-group",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:devsecopsAgent.results",
    "onCommand:devsecopsAgent.scanWorkspace",
    "onCommand:devsecopsAgent.refreshResults",
    "onCommand:devsecopsAgent.refresh",
    "onCommand:devsecopsAgent.showOnlySemgrepFindings",
    "onCommand:devsecopsAgent.showSast",
    "onCommand:devsecopsAgent.showAllFindings",
    "onCommand:devsecopsAgent.showAll",
    "onCommand:devsecopsAgent.showSecrets",
    "onCommand:devsecopsAgent.showScript",
    "onCommand:devsecopsAgent.showManifest",
    "onCommand:devsecopsAgent.showConfig",
    "onCommand:devsecopsAgent.showDependency",
    "onCommand:devsecopsAgent.openFinding"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devsecopsAgent.scanWorkspace",
        "title": "DevSecOps Agent: Scan Workspace",
        "category": "DevSecOps Agent",
        "icon": "$(play)"
      },
      {
        "command": "devsecopsAgent.refreshResults",
        "title": "DevSecOps Agent: Refresh Results",
        "category": "DevSecOps Agent",
        "icon": "$(refresh)"
      },
      {
        "command": "devsecopsAgent.showOnlySemgrepFindings",
        "title": "DevSecOps Agent: Show Only SAST Findings",
        "category": "DevSecOps Agent",
        "icon": "$(shield)"
      },
      {
        "command": "devsecopsAgent.showAllFindings",
        "title": "DevSecOps Agent: Show All Findings",
        "category": "DevSecOps Agent",
        "icon": "$(list-tree)"
      },
      {
        "command": "devsecopsAgent.showSecrets",
        "title": "DevSecOps Agent: Show Only Secrets Findings",
        "category": "DevSecOps Agent",
        "icon": "$(key)"
      },
      {
        "command": "devsecopsAgent.showScript",
        "title": "DevSecOps Agent: Show Only Script Findings",
        "category": "DevSecOps Agent",
        "icon": "$(code)"
      },
      {
        "command": "devsecopsAgent.showManifest",
        "title": "DevSecOps Agent: Show Only Kubernetes/Manifest Findings",
        "category": "DevSecOps Agent",
        "icon": "$(package)"
      },
      {
        "command": "devsecopsAgent.showConfig",
        "title": "DevSecOps Agent: Show Only Config Findings",
        "category": "DevSecOps Agent",
        "icon": "$(settings-gear)"
      },
      {
        "command": "devsecopsAgent.showDependency",
        "title": "DevSecOps Agent: Show Only Dependency Findings",
        "category": "DevSecOps Agent",
        "icon": "$(extensions)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "devsecopsAgent.results",
          "name": "DevSecOps Agent"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "devsecopsAgent.results",
        "when": "!devsecopsAgent.hasScanned && !devsecopsAgent.isScanning",
        "contents": "[Run Scan](command:devsecopsAgent.scanWorkspace)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "devsecopsAgent.scanWorkspace"
        },
        {
          "command": "devsecopsAgent.refreshResults"
        },
        {
          "command": "devsecopsAgent.showAllFindings"
        },
        {
          "command": "devsecopsAgent.showOnlySemgrepFindings"
        },
        {
          "command": "devsecopsAgent.showSecrets"
        },
        {
          "command": "devsecopsAgent.showScript"
        },
        {
          "command": "devsecopsAgent.showManifest"
        },
        {
          "command": "devsecopsAgent.showConfig"
        },
        {
          "command": "devsecopsAgent.showDependency"
        }
      ],
      "view/title": [
        {
          "command": "devsecopsAgent.scanWorkspace",
          "when": "view == devsecopsAgent.results",
          "group": "navigation@1"
        },
        {
          "command": "devsecopsAgent.refreshResults",
          "when": "view == devsecopsAgent.results",
          "group": "navigation@2"
        },
        {
          "command": "devsecopsAgent.showAllFindings",
          "when": "view == devsecopsAgent.results",
          "group": "navigation@3"
        },
        {
          "command": "devsecopsAgent.showOnlySemgrepFindings",
          "when": "view == devsecopsAgent.results",
          "group": "inline@1"
        },
        {
          "command": "devsecopsAgent.showSecrets",
          "when": "view == devsecopsAgent.results",
          "group": "inline@2"
        },
        {
          "command": "devsecopsAgent.showScript",
          "when": "view == devsecopsAgent.results",
          "group": "inline@3"
        },
        {
          "command": "devsecopsAgent.showManifest",
          "when": "view == devsecopsAgent.results",
          "group": "filters@4"
        },
        {
          "command": "devsecopsAgent.showConfig",
          "when": "view == devsecopsAgent.results",
          "group": "filters@5"
        },
        {
          "command": "devsecopsAgent.showDependency",
          "when": "view == devsecopsAgent.results",
          "group": "filters@6"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.4.5"
  }
}
